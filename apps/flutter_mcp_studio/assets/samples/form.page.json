{
  "slug": "form",
  "title": "Form Demo",
  "description": "MCP form demo with controlled fields, state bindings, and persisted versions.",
  "definition": {
    "type": "page",
    "title": "Form Demo",
    "state": {
      "initial": {
        "form": {
          "name": "华东大促活动审批",
          "owner": "李想",
          "priority": "high",
          "budget": 120000,
          "memo": "需要联合销售、客服、仓配三方执行。",
          "channel": "email"
        },
        "statusText": "草稿待确认"
      }
    },
    "content": {
      "type": "linear",
      "direction": "vertical",
      "gap": 16,
      "children": [
        {
          "type": "form",
          "title": "审批表单",
          "subtitle": "表单值实时写回状态树，人工可继续在编辑器中改 JSON。",
          "children": [
            {
              "type": "input",
              "label": "流程名称",
              "binding": "app.form.name",
              "placeholder": "请输入流程名称"
            },
            {
              "type": "input",
              "label": "负责人",
              "binding": "app.form.owner",
              "placeholder": "请输入负责人"
            },
            {
              "type": "select",
              "label": "优先级",
              "binding": "app.form.priority",
              "items": [
                {
                  "value": "low",
                  "label": "低"
                },
                {
                  "value": "medium",
                  "label": "中"
                },
                {
                  "value": "high",
                  "label": "高"
                }
              ]
            },
            {
              "type": "numberField",
              "label": "预算",
              "value": {
                "binding": "app.form.budget"
              },
              "prefix": "¥ ",
              "step": 1000,
              "change": {
                "type": "state",
                "action": "set",
                "binding": "app.form.budget",
                "value": "{{event.value}}"
              }
            },
            {
              "type": "select",
              "label": "通知渠道",
              "binding": "app.form.channel",
              "items": [
                {
                  "value": "email",
                  "label": "邮件"
                },
                {
                  "value": "wechat",
                  "label": "企业微信"
                },
                {
                  "value": "sms",
                  "label": "短信"
                }
              ]
            },
            {
              "type": "textarea",
              "label": "补充说明",
              "binding": "app.form.memo",
              "maxLines": 4,
              "placeholder": "请输入补充说明"
            }
          ]
        },
        {
          "type": "antdSection",
          "title": "操作栏",
          "subtitle": "状态文本：{{app.statusText}}",
          "child": {
            "type": "linear",
            "direction": "horizontal",
            "gap": 12,
            "wrap": true,
            "children": [
              {
                "type": "button",
                "label": "提交审批",
                "variant": "outlined",
                "click": {
                  "type": "state",
                  "action": "set",
                  "binding": "app.statusText",
                  "value": "已提交，等待审批"
                }
              },
              {
                "type": "button",
                "label": "固化表单版本",
                "variant": "filled",
                "backgroundColor": "#0f766e",
                "click": {
                  "type": "tool",
                  "tool": "persistPage",
                  "params": {
                    "slug": "form",
                    "title": "Form Demo",
                    "description": "审批表单示例页面",
                    "note": "Saved from form action"
                  }
                }
              }
            ]
          }
        }
      ]
    }
  }
}
