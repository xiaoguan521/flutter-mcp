{
  "name": "@workspace/mcp-ui-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted MCP UI server with versioned JSON page persistence.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
